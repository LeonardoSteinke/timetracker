# Nome do container (usado no docker-compose e como hostname no nginx)
PROJECT_NAME=timetracker

# Porta interna que a aplicação escuta (não publicada no host)
APP_PORT=3000

# Subdomínio público (timetracker.seudominio.com)
SUBDOMAIN=timetracker

# Fuso horário padrão da aplicação
TZ=America/Sao_Paulo

# ─── Segredos (gerar valores fortes!) ────────────────────────────────────────
# Assina os JWT de sessão. Gere com: openssl rand -hex 32
JWT_SECRET=troque-por-um-valor-aleatorio-forte

# Código exigido no cadastro de novos usuários (evita registro aberto na internet)
REGISTRATION_CODE=defina-um-codigo-de-convite
